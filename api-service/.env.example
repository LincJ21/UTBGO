# ==============================================================================
#  UTBGO — API SERVICE (Go/Gin)
#  Archivo de configuración de ejemplo
# ==============================================================================
#
#  INSTRUCCIONES PARA CONFIGURAR EL PROYECTO
#  ==========================================
#  1. Copia este archivo y renómbralo a ".env":
#       cp api-service/.env.example api-service/.env
#
#  2. Rellena CADA variable con tus propias credenciales.
#     Las variables marcadas con [REQUERIDO] son obligatorias para que
#     el servidor arranque. Las marcadas con [OPCIONAL] tienen un valor
#     por defecto o solo se necesitan en producción.
#
#  3. NUNCA subas el archivo ".env" real al repositorio.
#     Ya está protegido por el .gitignore.
#
# ==============================================================================


# ──────────────────────────────────────────────────────────────────────────────
# 1. SERVIDOR
# ──────────────────────────────────────────────────────────────────────────────

# Puerto en el que escucha el servidor HTTP [OPCIONAL - por defecto 8080]
PORT=8080

# Modo de Gin: "debug" para desarrollo local, "release" para producción [OPCIONAL]
GIN_MODE=debug

# Clave secreta para firmar los tokens JWT [REQUERIDO]
# Genera una clave segura con: openssl rand -hex 32
JWT_SECRET_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_SEGURA

# Orígenes permitidos para CORS (separados por coma) [REQUERIDO]
# Ejemplo desarrollo: http://localhost:3000,http://localhost:5173
# Ejemplo producción: https://app.utbgo.edu.co
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173


# ──────────────────────────────────────────────────────────────────────────────
# 2. BASE DE DATOS — PostgreSQL
# ──────────────────────────────────────────────────────────────────────────────
# Usa UNA de las dos opciones siguientes (no ambas).
#
# Opción A — Neon.tech (cloud PostgreSQL):
#   Entra a https://neon.tech → crea un proyecto → copia la "Connection string".
#   El formato es: postgres://usuario:contraseña@host/base_de_datos?sslmode=require
#
# Opción B — PostgreSQL local con Docker:
#   Levanta el contenedor con: docker-compose up -d postgres
#   Luego usa: postgres://postgres:postgres@localhost:5432/utbgo

# [REQUERIDO]
DB_CONNECTION_STRING=postgres://usuario:contraseña@host/base_de_datos?sslmode=require

# Alias alternativo (algunos módulos usan este nombre) [REQUERIDO]
DATABASE_URL=postgres://usuario:contraseña@host/base_de_datos?sslmode=require


# ──────────────────────────────────────────────────────────────────────────────
# 3. CACHÉ Y RATE-LIMITING — Redis
# ──────────────────────────────────────────────────────────────────────────────
# Opción A — Upstash Redis (cloud, gratis hasta cierto límite):
#   Entra a https://upstash.com → crea una base de datos Redis → copia la URL.
#   El formato es: rediss://default:contraseña@hostname:puerto
#
# Opción B — Redis local con Docker:
#   Levanta el contenedor con: docker-compose up -d redis
#   Luego usa: redis://localhost:6379

# [REQUERIDO]
REDIS_URL=redis://localhost:6379


# ──────────────────────────────────────────────────────────────────────────────
# 4. ALMACENAMIENTO DE MULTIMEDIA — Cloudinary
# ──────────────────────────────────────────────────────────────────────────────
# Proveedor activo (cloudinary o azure) [REQUERIDO]
STORAGE_PROVIDER=cloudinary

# Credenciales de Cloudinary [REQUERIDO si STORAGE_PROVIDER=cloudinary]
# Pasos:
#   1. Crea una cuenta gratuita en https://cloudinary.com
#   2. Ve a Dashboard → copia "API Environment variable"
#   3. Tiene el formato: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=cloudinary://TU_API_KEY:TU_API_SECRET@TU_CLOUD_NAME


# ──────────────────────────────────────────────────────────────────────────────
# 5. MICROSERVICIOS INTERNOS (Python)
# ──────────────────────────────────────────────────────────────────────────────
# URLs de los microservicios Python. En desarrollo local usa localhost.
# En Docker Compose usa el nombre del servicio (ej: http://tracking-service:8091)

# Servicio de tracking [REQUERIDO]
TRACKING_SERVICE_URL=http://localhost:8091
TRACKING_API_KEY=CAMBIA_ESTA_CLAVE_SECRETA_DE_TRACKING

# Servicio de recomendaciones [REQUERIDO]
RECOMMENDATIONS_SERVICE_URL=http://localhost:8090
RECOMMENDATIONS_API_KEY=CAMBIA_ESTA_CLAVE_SECRETA_DE_RECOMENDACIONES

# Motor de recomendaciones a usar: "custom_ml" o "simple" [OPCIONAL]
PRIMARY_RECOMMENDATION_ENGINE=custom_ml


# ──────────────────────────────────────────────────────────────────────────────
# 6. AUTENTICACIÓN CON GOOGLE / FIREBASE
# ──────────────────────────────────────────────────────────────────────────────
# El sistema usa Firebase Auth + Google OAuth para autenticación institucional.
#
# ► Paso A — Configurar Firebase:
#   1. Ve a https://console.firebase.google.com
#   2. Crea o selecciona tu proyecto
#   3. Ve a Configuración del proyecto → copia el "ID del proyecto"
#   4. Activa "Authentication" → método "Google"
#
# ► Paso B — Obtener Google Client ID (OAuth 2.0):
#   1. Ve a https://console.cloud.google.com
#   2. Selecciona el mismo proyecto de Firebase
#   3. Menú → APIs y servicios → Credenciales
#   4. Crea unas credenciales "ID de cliente OAuth 2.0" → tipo "Aplicación web"
#   5. Agrega los Orígenes autorizados (ej: http://localhost:3000)
#   6. Copia el "ID de cliente" que termina en .apps.googleusercontent.com
#
# ► Paso C — Credencial de cuenta de servicio de Firebase (para el backend Go):
#   1. En Firebase → Configuración → Cuentas de servicio
#   2. Genera una nueva clave privada (descarga el JSON)
#   3. Guarda ese JSON como: api-service/firebase-service-account.json
#      (ya está en el .gitignore, nunca lo subas al repo)

# ID del proyecto Firebase [REQUERIDO]
FIREBASE_PROJECT_ID=tu-proyecto-firebase

# Client ID de Google OAuth [REQUERIDO]
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com

# Dominio institucional permitido para el login [REQUERIDO]
INSTITUTIONAL_DOMAIN=utb.edu.co

# Dominio del panel administrador [REQUERIDO]
ADMIN_DOMAIN=admin.utb.edu.co
