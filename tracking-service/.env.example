# ==============================================================================
#  UTBGO — TRACKING SERVICE (Python/FastAPI + Alembic)
#  Archivo de configuración de ejemplo
# ==============================================================================
#
#  INSTRUCCIONES PARA CONFIGURAR EL SERVICIO
#  ==========================================
#  1. Copia este archivo y renómbralo a ".env":
#       cp tracking-service/.env.example tracking-service/.env
#
#  2. Rellena CADA variable con tus propias credenciales.
#     Las variables marcadas con [REQUERIDO] son obligatorias para arrancar.
#
#  3. Después de configurar la base de datos, aplica las migraciones:
#       cd tracking-service
#       python migrate.py
#
#  4. NUNCA subas el archivo ".env" real al repositorio.
#     Ya está protegido por el .gitignore.
#
# ==============================================================================


# ──────────────────────────────────────────────────────────────────────────────
# 1. SERVIDOR
# ──────────────────────────────────────────────────────────────────────────────

# Puerto del servicio [OPCIONAL - por defecto 8091]
PORT=8091

# Clave API con la que el api-service (Go) se autentica [REQUERIDO]
# Debe coincidir con TRACKING_API_KEY en api-service/.env
API_KEY=CAMBIA_ESTA_CLAVE_SECRETA_DE_TRACKING


# ──────────────────────────────────────────────────────────────────────────────
# 2. BASE DE DATOS — PostgreSQL (tabla de eventos de tracking)
# ──────────────────────────────────────────────────────────────────────────────
# Este servicio guarda TODOS los eventos de actividad (clicks, vistas, etc.).
# Puede compartir la misma instancia PostgreSQL que el api-service
# o usar una base de datos separada para mejor escalabilidad.
#
# Opción A — Neon.tech: postgres://usuario:contraseña@host/base_de_datos?sslmode=require
# Opción B — Local/Docker: postgres://postgres:postgres@localhost:5432/utbgo_tracking
#
# IMPORTANTE: Después de configurar esta variable, ejecuta las migraciones:
#   cd tracking-service && python migrate.py

# [REQUERIDO]
DATABASE_URL=postgres://usuario:contraseña@host/base_de_datos?sslmode=require


# ──────────────────────────────────────────────────────────────────────────────
# 3. CACHÉ — Redis
# ──────────────────────────────────────────────────────────────────────────────
# Usado para encolar eventos de tracking antes de persistirlos en la BD.
# Misma instancia Redis que usa el api-service.
#
# Opción A — Upstash: rediss://default:contraseña@hostname:puerto
# Opción B — Local:   redis://localhost:6379

# [REQUERIDO]
REDIS_URL=redis://localhost:6379


# ──────────────────────────────────────────────────────────────────────────────
# 4. CONFIGURACIÓN DEL WORKER
# ──────────────────────────────────────────────────────────────────────────────

# Cuántos eventos procesa el worker en cada ciclo [OPCIONAL]
BATCH_SIZE=100

# Intervalo en segundos entre cada ciclo del worker [OPCIONAL]
WORKER_INTERVAL_SECONDS=5

# Nivel de logs: DEBUG, INFO, WARNING, ERROR [OPCIONAL]
LOG_LEVEL=INFO
