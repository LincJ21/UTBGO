# ==============================================================================
#  UTBGO — RECOMMENDATIONS SERVICE (Python/FastAPI)
#  Archivo de configuración de ejemplo
# ==============================================================================
#
#  INSTRUCCIONES PARA CONFIGURAR EL SERVICIO
#  ==========================================
#  1. Copia este archivo y renómbralo a ".env":
#       cp recommendations-service/.env.example recommendations-service/.env
#
#  2. Rellena CADA variable con tus propias credenciales.
#     Las variables marcadas con [REQUERIDO] son obligatorias para arrancar.
#
#  3. NUNCA subas el archivo ".env" real al repositorio.
#     Ya está protegido por el .gitignore.
#
# ==============================================================================


# ──────────────────────────────────────────────────────────────────────────────
# 1. SERVIDOR
# ──────────────────────────────────────────────────────────────────────────────

# Puerto del servicio [OPCIONAL - por defecto 8090]
PORT=8090

# Clave API con la que el api-service (Go) se autentica [REQUERIDO]
# Debe coincidir con RECOMMENDATIONS_API_KEY en api-service/.env
API_KEY=CAMBIA_ESTA_CLAVE_SECRETA_DE_RECOMENDACIONES


# ──────────────────────────────────────────────────────────────────────────────
# 2. BASE DE DATOS — PostgreSQL
# ──────────────────────────────────────────────────────────────────────────────
# Este servicio lee los datos de actividad de los usuarios desde PostgreSQL.
#
# Usa la misma cadena de conexión que el api-service.
# Opción A — Neon.tech: postgres://usuario:contraseña@host/base_de_datos?sslmode=require
# Opción B — Local/Docker: postgres://postgres:postgres@localhost:5432/utbgo

# [REQUERIDO]
DATABASE_URL=postgres://usuario:contraseña@host/base_de_datos?sslmode=require


# ──────────────────────────────────────────────────────────────────────────────
# 3. CACHÉ — Redis
# ──────────────────────────────────────────────────────────────────────────────
# Usado para cachear recomendaciones pre-calculadas.
# Misma instancia Redis que usa el api-service.
#
# Opción A — Upstash: rediss://default:contraseña@hostname:puerto
# Opción B — Local:   redis://localhost:6379

# [REQUERIDO]
REDIS_URL=redis://localhost:6379


# ──────────────────────────────────────────────────────────────────────────────
# 4. MODELO DE MACHINE LEARNING
# ──────────────────────────────────────────────────────────────────────────────

# Número de recomendaciones a generar por usuario [OPCIONAL]
RECOMMENDATION_COUNT=10

# Número mínimo de interacciones para incluir un usuario en el modelo [OPCIONAL]
MIN_INTERACTIONS=3

# Nivel de logs: DEBUG, INFO, WARNING, ERROR [OPCIONAL]
LOG_LEVEL=INFO
