# ==============================================================================
#  ARCHIVO DE CONFIGURACIÓN DE EJEMPLO 
# ==============================================================================
# Instrucciones:
# 1. Copia este archivo y cámbiale el nombre a '.env'
# 2. Rellena los valores con tus propias credenciales de servicios Cloud.
# ==============================================================================

# --- 1. CONFIGURACIÓN DEL SERVIDOR (API GO) ---
PORT=8080
GIN_MODE=debug
JWT_SECRET_KEY=tu_secreto_para_jwt_aqui
ALLOWED_ORIGINS=*

# --- 2. BASE DE DATOS (Neon.tech o PostgreSQL Local) ---
# Ejemplo: postgres://user:password@hostname/dbname?sslmode=require
DB_CONNECTION_STRING=
DATABASE_URL=

# --- 3. CACHÉ Y RATE LIMITING (Upstash Redis o Redis Local) ---
# Formato Upstash: rediss://default:password@hostname:port
REDIS_URL=redis://localhost:6379

# --- 4. ALMACENAMIENTO DE MULTIMEDIA (Cloudinary) ---
# Formato: cloudinary://api_key:api_secret@cloud_name
STORAGE_PROVIDER=cloudinary
CLOUDINARY_URL=

# --- 5. MICROSERVICIOS (Python) ---
TRACKING_SERVICE_URL=http://localhost:8091
TRACKING_API_KEY=super-secret-tracking-key
RECOMMENDATIONS_SERVICE_URL=http://localhost:8090
RECOMMENDATIONS_API_KEY=super-secret-recs-key
PRIMARY_RECOMMENDATION_ENGINE=custom_ml

# --- 6. AUTENTICACIÓN INSTITUCIONAL (UTB) ---
FIREBASE_PROJECT_ID=tu-proyecto-firebase
GOOGLE_CLIENT_ID=tu-google-client-id.apps.googleusercontent.com
INSTITUTIONAL_DOMAIN=utb.edu.co
ADMIN_DOMAIN=admin.utb.edu.co
